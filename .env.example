# --- Anthropic API ---
ANTHROPIC_API_KEY=
# Default per project spec. If this exact model id is not valid at the
# time you run this, substitute a current model id (e.g. claude-sonnet-5).
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- cTrader Remote MCP ---
# 1. Log in to cTrader Web with your DEMO account.
# 2. Go to Settings -> Remote MCP.
# 3. Generate a bearer token there. It is tied to your active Web session
#    and CAN EXPIRE -- this app does not silently retry auth forever, you
#    must regenerate it manually and paste the new value here (or use the
#    dashboard's Reconnect form, which hot-reloads it without a restart).
# 4. Copy the EXACT Remote MCP server URL shown on that same page into
#    CTRADER_MCP_SERVER_URL below. Do NOT guess this URL -- it is
#    intentionally left blank in this repo, never hardcoded.
CTRADER_MCP_MODE=remote
CTRADER_MCP_SERVER_URL=
CTRADER_MCP_TOKEN=
CTRADER_ACCOUNT_ID=
CTRADER_ENVIRONMENT=demo

# --- Persistence ---
TRADALGO_DB_PATH=decision_log/tradalgo.db

# --- Dashboard (Flask, default port 8002 -- next to InvestAlgo:8001 and ClubInvest:8000) ---
DASHBOARD_PORT=8002
DASHBOARD_PASSWORD=
DASHBOARD_SECRET_KEY=

# --- Scheduler ---
SCHEDULER_LATENCY_BUFFER_SECONDS=45
SCHEDULER_MAX_PROCESSING_TIME_SECONDS=300

# --- Alerting (optional) ---
# If set, the dashboard POSTs a small JSON payload here when the MCP token
# flips healthy -> unhealthy (e.g. a Telegram bot webhook or generic
# incoming-webhook URL). Leave blank to disable.
TRADALGO_ALERT_WEBHOOK_URL=
